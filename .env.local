# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ams_db?sslmode=disable
# .env.supabase
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ams_db
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Secret (Change in production!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d
